<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ http://wowprogramming.com/FrameXML/UI.xsd">
    <Script file="IPAInstancePortalPinTemplate.lua"/>
    
    <Frame name="IPAInstancePortalPinTemplate"
        enableMouseClicks="true"
        enableMouseMotion="true"
        mixin="IPAInstancePortalProviderPinMixin"
        virtual="true">
        
        <Size x="32" y="32"/>
        
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="SuperTrackGlow" atlas="UI-QuestPoi-OuterGlow" hidden="true">
					 <Size x="40" y="40"/>
                    <Anchors>
                        <Anchor point="CENTER" x="0" y="0"/>
                    </Anchors>
                </Texture>
            </Layer>
            
            <Layer level="ARTWORK">
                <Texture parentKey="Texture">
                    <Size x="20" y="20"/>
                    <Anchors>
                        <Anchor point="CENTER" x="0" y="0"/>
                    </Anchors>
                </Texture>
            </Layer>
            
            <Layer level="ARTWORK" textureSubLevel="7">
                <Texture parentKey="SuperTrackMarker" atlas="Waypoint-MapPin-Tracked" hidden="true">
                    <Size x="20" y="20"/>
                    <Anchors>
                        <Anchor point="CENTER" x="7" y="-7"/>
                    </Anchors>
                </Texture>
            </Layer>
            
            <Layer level="HIGHLIGHT">
				<Texture parentKey="HighlightTexture" alphaMode="ADD" alpha="0.4">
					<Size x="20" y="20"/>
					<Anchors>
						<Anchor point="CENTER" x="0" y="0"/>
					</Anchors>
				</Texture>
			</Layer>
        </Layers>
        
        <Scripts>
            <OnLoad method="OnLoad"/>
        </Scripts>
        
    </Frame>
</Ui>